# =============================================================================
# openfortivpn configuration
# =============================================================================
# Copy this file to 'config' and fill in your credentials:
#   cp config.example config
#
# Finding the trusted-cert hash:
#   Run openfortivpn once without trusted-cert. It will fail but print:
#     ERROR: Gateway certificate validation failed, and the certificate
#     digest is not in the local whitelist. If you trust it, rerun with:
#       --trusted-cert <hash>
#   Copy that hash into the trusted-cert field below.
# =============================================================================

host = vpn.example.com
port = 443
# realm = <realm-if-required>
username = your_username
password = your_password

# SSL verification (pick one):
# Option A: Certificate hash from first connection attempt (see instructions above)
# trusted-cert = 1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
# Option B: CA certificate file (e.g. from your IT department, mounted into container)
# ca-file = /etc/ssl/certs/your-ca.crt
