# Template — copy to secret.yaml, fill in the real DSN, then:
#   kubectl apply -f secret.yaml
# Do NOT commit the filled-in version. Add `secret.yaml` to your local .gitignore
# if you plan to keep it in-tree.
#
# API keys themselves are NOT configured here (or anywhere in YAML) — they
# live in Postgres and are managed through the admin UI. This secret only
# carries the connection string the router (and the admin UI, if you deploy
# it on the cluster) uses to reach that database.
apiVersion: v1
kind: Secret
metadata:
  name: model-orchestrator-keys
  namespace: model-orchestrator
  labels:
    app.kubernetes.io/name: model-orchestrator
type: Opaque
stringData:
  database-url: "postgresql://orchestrator:change-me@postgres.example.svc:5432/orchestrator"
