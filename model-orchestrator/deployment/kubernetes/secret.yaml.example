# Template — copy to secret.yaml, fill in real keys, then:
#   kubectl apply -f secret.yaml
# Do NOT commit the filled-in version. Add `secret.yaml` to your local .gitignore
# if you plan to keep it in-tree.
#
# The `keys.yaml` content below is mounted at /app/keys.yaml in the pod and
# read via the ROUTER_KEYS_CONFIG env var. Its `api_keys:` list is merged
# with whatever's in the ConfigMap's config.yaml at startup (which should
# have no api_keys of its own — the whole point of splitting them out).
apiVersion: v1
kind: Secret
metadata:
  name: model-orchestrator-keys
  namespace: model-orchestrator
  labels:
    app.kubernetes.io/name: model-orchestrator
type: Opaque
stringData:
  keys.yaml: |
    api_keys:
      - key: "sk-change-me-admin-key"
        owner: "admin"
        tier: "admin"
        enabled: true
        name: "Admin Key"
      - key: "sk-change-me-standard-key"
        owner: "engineering"
        tier: "standard"
        enabled: true
        name: "Production Standard Key"
