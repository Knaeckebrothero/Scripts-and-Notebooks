# Template — copy to vpn-secret.yaml, fill in real credentials, then:
#   kubectl apply -f vpn-secret.yaml
# Do NOT commit the filled-in version.
#
# This Secret is envFrom'd into the vpn-sidecar container. See the sidecar
# README (devops/vpn-sidecar/README.md) for how to find VPN_TRUSTED_CERT.
#
# Omit the entire Secret (and the sidecar container in deployment.yaml) if
# you don't need VPN-routed backends.
#
# Two tunnels? Copy this file to vpn-secret-b.yaml, rename the Secret to
# `model-orchestrator-vpn-b`, fill in Network B credentials, set
# SOCKS_PORT=1081 and HEALTH_PORT=8082 (both sidecars share the pod's
# network namespace, so the SOCKS and health ports must be distinct), and
# uncomment the `vpn-sidecar-b` container in deployment.yaml. Routes then
# reference it via `proxy: socks5h://127.0.0.1:1081`.
apiVersion: v1
kind: Secret
metadata:
  name: model-orchestrator-vpn
  namespace: model-orchestrator
  labels:
    app.kubernetes.io/name: model-orchestrator
type: Opaque
stringData:
  VPN_HOST: "vpn.example.com"
  VPN_PORT: "443"
  VPN_USER: "your_username"
  VPN_PASS: "your_password"
  VPN_TRUSTED_CERT: "replace-with-64-char-sha256"
  # VPN_REALM: "pub-all"          # optional
  # SOCKS_PORT: "1080"            # optional, defaults to 1080
  # HEALTH_PORT: "8081"           # optional, defaults to 8081 (liveness probe)
