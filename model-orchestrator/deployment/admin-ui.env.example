# Copy to ~/.config/model-orchestrator/admin-ui.env and chmod 600.
# Consumed by admin-ui.container. DSN password must match db.env.
DATABASE_URL=postgresql://orchestrator:change-me@127.0.0.1:5432/orchestrator
UI_ADMIN_USER=admin
UI_ADMIN_PASSWORD=change-me

# The public address/port browsers reach the UI at (the nginx listener).
# Required when that is not localhost: Streamlit's CORS check only accepts
# websocket upgrades from localhost or this address — without it the page
# shell loads but hangs on the loading screen (403 on /_stcore/stream).
STREAMLIT_BROWSER_SERVER_ADDRESS=the-public-hostname-or-ip
STREAMLIT_BROWSER_SERVER_PORT=8501
